# Port (default: 3100)
PORT=3100

# --- Optional: n8n workflow write ---
# Set to "true" to enable n8n_create_workflow and n8n_update_workflow tools
# ALLOW_N8N_WRITE=false

# n8n instance URL (when ALLOW_N8N_WRITE=true)
# N8N_BASE_URL=http://localhost:5678

# n8n API key (required for workflow create/update)
# N8N_API_KEY=your-api-key
