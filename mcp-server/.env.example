PORT=8787

# ── mcp-hub Authentication ───────────────────────────────────────────────────
# Leave all three blank to run in open mode (no auth — dev/local only).
# Set at least HUB_READ_KEY to enable auth.
#
# Key scopes:
#   HUB_READ_KEY  → read  (catalog, search, list)
#   HUB_WRITE_KEY → read + write (apply workflows, create Notion entries)
#   HUB_ADMIN_KEY → read + write + danger (all operations)
#
HUB_READ_KEY=
HUB_WRITE_KEY=
HUB_ADMIN_KEY=

# ── Plugin Enable/Disable ───────────────────────────────────────────────────
# Set to "false" to disable specific plugins (useful for non-n8n deployments)
ENABLE_N8N_PLUGIN=true
ENABLE_N8N_CREDENTIALS=true
ENABLE_N8N_WORKFLOWS=true

# ── Audit Logging ────────────────────────────────────────────────────────────
# Set to "true" to also write audit logs to cache/audit.log
AUDIT_LOG_FILE=false

# n8n access
N8N_BASE_URL=http://n8n:5678
# n8n REST API base path (default: /api/v1)
N8N_API_BASE=/api/v1
# Required for credential/workflow read and write operations
N8N_API_KEY=
ALLOW_N8N_WRITE=false

# n8n node catalog cache
CATALOG_CACHE_DIR=./cache
CATALOG_TTL_HOURS=24

# n8n-credentials plugin: how long to cache credential list (minutes)
CREDENTIALS_TTL_MINUTES=60

# n8n-workflows plugin: how long to cache workflow list and detail (minutes)
WORKFLOWS_TTL_MINUTES=10

# Notion plugin
# Create an integration at https://www.notion.so/my-integrations
# Share your pages/databases with the integration to grant access
NOTION_API_KEY=
# Optional: default parent page ID for new pages (if not specified per-request)
NOTION_ROOT_PAGE_ID=
# Database IDs for setup-project and task endpoints
NOTION_PROJECTS_DB_ID=
NOTION_TASKS_DB_ID=

# GitHub plugin
# Create a token at https://github.com/settings/tokens
# Required scopes: repo (for private repos), public_repo (for public only)
# Without a token, only public repos are accessible (rate limit: 60 req/hour)
GITHUB_TOKEN=

# ── Slack plugin ───────────────────────────────────────────────────────────────
# Create a bot at https://api.slack.com/apps
# Bot token should start with "xoxb-"
SLACK_BOT_TOKEN=

# ── openapi plugin ────────────────────────────────────────────────────────────
# Where loaded specs are cached on disk
OPENAPI_CACHE_DIR=./cache/openapi

# ── http plugin ───────────────────────────────────────────────────────────────
# Comma-separated domain allowlist (empty = allow all non-blocked domains)
# Supports wildcards: *.github.com
HTTP_ALLOWED_DOMAINS=
# Comma-separated blocked domains (always blocked regardless of allowlist)
HTTP_BLOCKED_DOMAINS=
# Maximum response body size to read (in KB)
HTTP_MAX_RESPONSE_SIZE_KB=512
# Request timeout in milliseconds
HTTP_DEFAULT_TIMEOUT_MS=10000
# Max requests per minute per domain (rate limiter)
HTTP_RATE_LIMIT_RPM=60
# TTL for cached GET responses (in seconds)
HTTP_CACHE_TTL_SECONDS=300

# ── observability plugin ──────────────────────────────────────────────────────
# Optional: set to enable Sentry error tracking (requires npm install @sentry/node)
SENTRY_DSN=

# ── database plugin ──────────────────────────────────────────────────────────
MSSQL_CONNECTION_STRING=
PG_CONNECTION_STRING=
MONGODB_URI=

# ── Redis (required for pattern caching and draft sessions) ─────────────────
REDIS_URL=redis://localhost:6379
# Pattern cache TTL (days)
PATTERN_CACHE_TTL_DAYS=7
# Draft session TTL (hours)
DRAFT_SESSION_TTL_HOURS=1
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=

# ── brain plugin (AI/LLM integration) ─────────────────────────────────────────
# Required for AI-powered skills, chat, and project planning
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Optional: Override OpenAI base URL (for Azure, local models, etc.)
BRAIN_LLM_URL=https://api.openai.com/v1
# Optional: Model selection (gpt-4o, gpt-4o-mini, gpt-4, etc.)
BRAIN_LLM_MODEL=gpt-4o-mini

# ── workspace plugin (file operations) ──────────────────────────────────────
# Root directory for project workspaces
# Each projectId gets its own subdirectory: WORKSPACE_PATH/{projectId}/
WORKSPACE_PATH=./workspace

# ── git plugin (repository operations) ────────────────────────────────────────
# Optional: Default author name for commits (if not specified per-request)
GIT_DEFAULT_AUTHOR_NAME=Jarvis
# Optional: Default author email for commits
GIT_DEFAULT_AUTHOR_EMAIL=jarvis@localhost

# ── rag plugin (document indexing & search) ──────────────────────────────────
# Vector store type: memory (default), redis, pinecone, weaviate
RAG_VECTOR_STORE_TYPE=memory
# For Redis: redis://localhost:6379
RAG_REDIS_URL=
# For Pinecone: your Pinecone API key
RAG_PINECONE_API_KEY=
RAG_PINECONE_INDEX=
# For Weaviate: http://localhost:8080
RAG_WEAVIATE_URL=
# Embedding model for semantic search (default: text-embedding-3-small)
RAG_EMBEDDING_MODEL=text-embedding-3-small
# Max documents to index in one batch
RAG_MAX_BATCH_SIZE=100

# ── tests plugin (test runner) ──────────────────────────────────────────────
# Default timeout for test runs (milliseconds)
TESTS_DEFAULT_TIMEOUT_MS=60000
# Default test pattern (glob)
TESTS_DEFAULT_PATTERN="**/*.test.js"
# Coverage output directory
TESTS_COVERAGE_DIR=./coverage

# ── project-orchestrator plugin (AI project planning) ───────────────────────
# Optional: Override MCP server URL (defaults to http://localhost:8787)
MCP_SERVER_URL=http://localhost:8787
# Optional: Default tech stack suggestion for new projects
DEFAULT_TECH_STACK="Node.js, Express"
# Optional: Enable auto-execution of first phase (true/false)
PROJECT_AUTO_EXECUTE=false

# ── github-pattern-analyzer plugin ─────────────────────────────────────────
# Number of repos to analyze (default: 5)
GITHUB_ANALYZE_REPO_COUNT=5
# Minimum confidence threshold to accept patterns (0-1)
PATTERN_CONFIDENCE_THRESHOLD=0.7

# ── policy plugin (approval workflows) ──────────────────────────────────────
# Already covered by HUB_ADMIN_KEY above
