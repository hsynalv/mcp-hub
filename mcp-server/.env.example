PORT=8787

# ── mcp-hub Authentication ───────────────────────────────────────────────────
# Leave all three blank to run in open mode (no auth — dev/local only).
# Set at least HUB_READ_KEY to enable auth.
#
# Key scopes:
#   HUB_READ_KEY  → read  (catalog, search, list)
#   HUB_WRITE_KEY → read + write (apply workflows, create Notion entries)
#   HUB_ADMIN_KEY → read + write + danger (all operations)
#
HUB_READ_KEY=
HUB_WRITE_KEY=
HUB_ADMIN_KEY=

# ── Plugin Enable/Disable ───────────────────────────────────────────────────
# Set to "false" to disable specific plugins (useful for non-n8n deployments)
ENABLE_N8N_PLUGIN=true
ENABLE_N8N_CREDENTIALS=true
ENABLE_N8N_WORKFLOWS=true

# ── Audit Logging ────────────────────────────────────────────────────────────
# Set to "true" to also write audit logs to cache/audit.log
AUDIT_LOG_FILE=false

# n8n access
N8N_BASE_URL=http://n8n:5678
# n8n REST API base path (default: /api/v1)
N8N_API_BASE=/api/v1
# Required for credential/workflow read and write operations
N8N_API_KEY=
ALLOW_N8N_WRITE=false

# n8n node catalog cache
CATALOG_CACHE_DIR=./cache
CATALOG_TTL_HOURS=24

# n8n-credentials plugin: how long to cache credential list (minutes)
CREDENTIALS_TTL_MINUTES=60

# n8n-workflows plugin: how long to cache workflow list and detail (minutes)
WORKFLOWS_TTL_MINUTES=10

# Notion plugin
# Create an integration at https://www.notion.so/my-integrations
# Share your pages/databases with the integration to grant access
NOTION_API_KEY=
# Optional: default parent page ID for new pages (if not specified per-request)
NOTION_ROOT_PAGE_ID=
# Database IDs for setup-project and task endpoints
NOTION_PROJECTS_DB_ID=
NOTION_TASKS_DB_ID=

# GitHub plugin
# Create a token at https://github.com/settings/tokens
# Required scopes: repo (for private repos), public_repo (for public only)
# Without a token, only public repos are accessible (rate limit: 60 req/hour)
GITHUB_TOKEN=

# ── Slack plugin ───────────────────────────────────────────────────────────────
# Create a bot at https://api.slack.com/apps
# Bot token should start with "xoxb-"
SLACK_BOT_TOKEN=

# ── openapi plugin ────────────────────────────────────────────────────────────
# Where loaded specs are cached on disk
OPENAPI_CACHE_DIR=./cache/openapi

# ── http plugin ───────────────────────────────────────────────────────────────
# Comma-separated domain allowlist (empty = allow all non-blocked domains)
# Supports wildcards: *.github.com
HTTP_ALLOWED_DOMAINS=
# Comma-separated blocked domains (always blocked regardless of allowlist)
HTTP_BLOCKED_DOMAINS=
# Maximum response body size to read (in KB)
HTTP_MAX_RESPONSE_SIZE_KB=512
# Request timeout in milliseconds
HTTP_DEFAULT_TIMEOUT_MS=10000
# Max requests per minute per domain (rate limiter)
HTTP_RATE_LIMIT_RPM=60
# TTL for cached GET responses (in seconds)
HTTP_CACHE_TTL_SECONDS=300

# ── observability plugin ──────────────────────────────────────────────────────
# Optional: set to enable Sentry error tracking (requires npm install @sentry/node)
SENTRY_DSN=

# ── file-storage plugin ───────────────────────────────────────────────────────
FILE_STORAGE_LOCAL_ROOT=./cache/files
# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1
S3_BUCKET=
# Google Drive (OAuth2)
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=

# ── database plugin ──────────────────────────────────────────────────────────
MSSQL_CONNECTION_STRING=
PG_CONNECTION_STRING=
MONGODB_URI=

# ── Redis (for caching and resilience) ───────────────────────────────────────
REDIS_URL=redis://localhost:6379
# Pattern cache TTL (days)
PATTERN_CACHE_TTL_DAYS=7
# Draft session TTL (hours)
DRAFT_SESSION_TTL_HOURS=1

# ── Resilience Configuration (Retry & Circuit Breaker) ──────────────────────
# Max retry attempts for external API calls
RETRY_MAX_ATTEMPTS=3
# Base backoff time in milliseconds
RETRY_BACKOFF_MS=1000
# Max backoff time in milliseconds
RETRY_MAX_BACKOFF_MS=30000
# Circuit breaker failure threshold
CIRCUIT_FAILURE_THRESHOLD=5
# Circuit breaker reset timeout (ms)
CIRCUIT_RESET_TIMEOUT_MS=30000

# ── brain plugin (LLM) ───────────────────────────────────────────────────────
# OpenAI API key (primary)
OPENAI_API_KEY=
# Alternative LLM provider settings
BRAIN_LLM_API_KEY=
BRAIN_LLM_URL=https://api.openai.com/v1
BRAIN_LLM_MODEL=gpt-4o-mini

# ── project-orchestrator plugin ──────────────────────────────────────────────
# MCP server URL for tool calls
MCP_SERVER_URL=http://localhost:8787
# Default tech stack for new projects
DEFAULT_TECH_STACK=node,express,postgres
# Auto-execute tasks (false = manual approval)
PROJECT_AUTO_EXECUTE=false

# ── tests plugin ─────────────────────────────────────────────────────────────
# Test timeout in milliseconds
TEST_TIMEOUT_MS=30000
# Test file pattern
TEST_PATTERN=**/*.test.js
# Coverage output directory
COVERAGE_DIR=./coverage

# ── rag plugin (Retrieval Augmented Generation) ──────────────────────────────
# Vector database provider (pinecone, weaviate, pgvector)
RAG_VECTOR_PROVIDER=
# Pinecone settings
PINECONE_API_KEY=
PINECONE_INDEX=
PINECONE_ENVIRONMENT=
# Weaviate settings
WEAVIATE_URL=
WEAVIATE_API_KEY=

# ── workspace plugin ─────────────────────────────────────────────────────────
# Base path for file operations
WORKSPACE_PATH=./workspace

# ── git plugin ───────────────────────────────────────────────────────────────
# Git author settings
GIT_USER_NAME=MCP Hub
GIT_USER_EMAIL=mcp@localhost
# Auto-commit changes
GIT_AUTO_COMMIT=false

# ── policy plugin ────────────────────────────────────────────────────────────
# Default policy preset (strict, moderate, permissive)
POLICY_DEFAULT_PRESET=moderate
# Require approval for write operations
POLICY_REQUIRE_APPROVAL=true

# ── secrets plugin ───────────────────────────────────────────────────────────
# Secrets encryption key (generate with: openssl rand -hex 32)
SECRETS_ENCRYPTION_KEY=

# ── docker plugin ────────────────────────────────────────────────────────────
# Docker socket path (use /var/run/docker.sock on macOS/Linux)
DOCKER_SOCKET_PATH=/var/run/docker.sock
# Docker registry credentials
DOCKER_REGISTRY_USERNAME=
DOCKER_REGISTRY_PASSWORD=

# ── github-pattern-analyzer plugin ───────────────────────────────────────────
# GitHub token for repo analysis (separate from GITHUB_TOKEN if needed)
GITHUB_PATTERN_TOKEN=
# Max repos to analyze
GITHUB_MAX_REPOS=5

# ── file-watcher plugin ──────────────────────────────────────────────────────
# No additional config required - uses fs.watch
# Optional: Allowed directories for watching
ALLOWED_WATCH_DIRS=./src,./workspace

# ── shell plugin ─────────────────────────────────────────────────────────────
# Allowed working directories for shell commands (comma-separated)
ALLOWED_WORKING_DIRS=./workspace,./src,./tests
# Max command execution timeout (ms)
SHELL_MAX_TIMEOUT=60000

# ── email plugin ─────────────────────────────────────────────────────────────
# SMTP configuration for sending emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
# Default from address
EMAIL_FROM=noreply@localhost

# ── notifications plugin ──────────────────────────────────────────────────────
# No additional config required - uses native OS notifications

# ── Monitoring & Logging ────────────────────────────────────────────────────
# Log level (DEBUG, INFO, WARN, ERROR, FATAL)
LOG_LEVEL=INFO
# Log to console (true/false)
LOG_TO_CONSOLE=true
# Log to file (true/false) - enables structured JSON logging
LOG_TO_FILE=false
# Log file path
LOG_FILE_PATH=./logs/mcp-server.log
# Max log file size in MB before rotation
LOG_MAX_SIZE_MB=100
# Number of rotated log files to keep
LOG_MAX_FILES=5
# Prometheus metrics enabled
METRICS_ENABLED=true
# Metrics endpoint (default: /metrics)
METRICS_PATH=/metrics
