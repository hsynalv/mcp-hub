PORT=8787

# n8n access
N8N_BASE_URL=http://n8n:5678
# n8n REST API base path (default: /api/v1)
N8N_API_BASE=/api/v1
# Required for credential/workflow read and write operations
N8N_API_KEY=
ALLOW_N8N_WRITE=false

# n8n node catalog cache
CATALOG_CACHE_DIR=./cache
CATALOG_TTL_HOURS=24

# n8n-credentials plugin: how long to cache credential list (minutes)
CREDENTIALS_TTL_MINUTES=60

# n8n-workflows plugin: how long to cache workflow list and detail (minutes)
WORKFLOWS_TTL_MINUTES=10
