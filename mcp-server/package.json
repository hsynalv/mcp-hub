{
  "name": "ai-hub",
  "version": "1.0.0",
  "description": "Universal tool and service bridge for AI agents",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "mcp-hub-stdio": "./bin/mcp-hub-stdio.js"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\"",
    "prepare": "husky",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "ai",
    "agents",
    "automation",
    "cursor",
    "claude",
    "llm",
    "mcp",
    "github",
    "notion",
    "api"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/eslintrc": "^2.1.4",
    "@eslint/js": "^9.0.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "supertest": "^6.3.4",
    "vitest": "^1.6.0"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1001.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-async-errors": "^3.1.1",
    "googleapis": "^171.4.0",
    "ioredis": "^5.10.0",
    "js-yaml": "^4.1.1",
    "mongodb": "^7.1.0",
    "morgan": "^1.10.0",
    "mssql": "^12.2.0",
    "n8n-core": "^1.122.16",
    "n8n-nodes-base": "^1.121.15",
    "n8n-workflow": "^1.120.9",
    "pg": "^8.19.0",
    "zod": "^3.23.8"
  }
}
