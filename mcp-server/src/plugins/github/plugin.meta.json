{
  "name": "github",
  "version": "1.0.0",
  "status": "stable",
  "owner": "hsynalv",
  "description": "GitHub API integration for repository analysis, PR management, and code operations",
  "requiresAuth": true,
  "supportsJobs": false,
  "supportsStreaming": false,
  "testLevel": "unit",
  "resilience": {
    "retry": true,
    "timeout": 30000,
    "circuitBreaker": true
  },
  "security": {
    "scope": "read",
    "dangerousCombinations": ["shell", "docker"],
    "requiresApproval": false
  },
  "performance": {
    "avgResponseTimeMs": 1500,
    "maxConcurrent": 20
  },
  "documentation": {
    "readme": true,
    "examples": true,
    "apiReference": true
  },
  "dependencies": [],
  "envVars": [
    {
      "name": "GITHUB_TOKEN",
      "required": true,
      "description": "GitHub personal access token for API access"
    }
  ]
}
